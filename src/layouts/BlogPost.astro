---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import FallbackImage from '../assets/blog-placeholder-2.jpg';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, heroImageUrl } = Astro.props;
---

<html lang="es">
	<head>
		<BaseHead title={title} description={description} image={heroImage ?? FallbackImage} />
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{
						heroImageUrl ? (
							<img src={heroImageUrl} alt="" loading="eager" />
						) : (
							<Image width={1120} height={620} src={heroImage ?? FallbackImage} alt="" />
						)
					}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Actualizado el <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<p class="description">{description}</p>
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: min(980px, calc(100% - 32px));
	}
	.hero-image {
		overflow: hidden;
		border-radius: 8px;
		background: var(--line);
	}
	.hero-image img {
		display: block;
		width: 100%;
		max-height: 520px;
		object-fit: cover;
		border-radius: 0;
	}
	.prose {
		width: min(720px, 100%);
		margin: 0 auto;
		padding: 38px 0 0;
		color: var(--ink);
	}
	.title {
		margin-bottom: 34px;
	}
	.title h1 {
		margin: 8px 0 16px;
	}
	.description {
		margin: 0;
		color: var(--muted);
		font-size: 1.1rem;
	}
	.date {
		margin-bottom: 0.5em;
		color: var(--warm);
		font-size: 0.8rem;
		font-weight: 700;
		text-transform: uppercase;
	}
	.last-updated-on {
		color: var(--muted);
		font-style: italic;
		font-weight: 400;
		text-transform: none;
	}
</style>
