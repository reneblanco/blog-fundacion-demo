---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import FallbackImage from '../../assets/blog-placeholder-2.jpg';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { getSanityPosts } from '../../lib/sanity';

const sanityPosts = await getSanityPosts();
const localPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const posts =
	sanityPosts.length > 0
		? sanityPosts.map((post) => ({
				slug: post.slug,
				title: post.title,
				description: post.description,
				pubDate: new Date(post.publishedAt),
				heroImageUrl: post.heroImageUrl,
			}))
		: localPosts.map((post) => ({
				slug: post.id,
				title: post.data.title,
				description: post.data.description,
				pubDate: post.data.pubDate,
				heroImage: post.data.heroImage,
			}));
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={`Blog | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="blog-hero">
				<p class="eyebrow">Archivo editorial</p>
				<h1>Blog</h1>
				<p>
					Consulta noticias, testimonios y recursos publicados por el equipo. Las entradas nuevas
					creadas desde el panel apareceran aqui automaticamente.
				</p>
			</section>
			<section>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.slug}/`}>
									{
										post.heroImageUrl ? (
											<img src={post.heroImageUrl} alt="" loading="lazy" />
										) : (
											<Image width={720} height={450} src={post.heroImage ?? FallbackImage} alt="" />
										)
									}
									<div class="card-copy">
										<p class="date">
											<FormattedDate date={post.pubDate} />
										</p>
										<h2 class="title">{post.title}</h2>
										<p class="description">{post.description}</p>
									</div>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.blog-hero {
		display: grid;
		gap: 12px;
		max-width: 780px;
		margin-bottom: 42px;
	}
	.blog-hero p {
		margin: 0;
		color: var(--muted);
		font-size: 1.1rem;
	}
	.eyebrow {
		color: var(--warm);
		font-size: 0.78rem;
		font-weight: 700;
		text-transform: uppercase;
	}
	ul {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 18px;
		list-style-type: none;
		margin: 0;
		padding: 0;
	}
	ul li {
		min-width: 0;
	}
	ul li:first-child {
		grid-column: span 2;
	}
	ul li a {
		display: flex;
		height: 100%;
		overflow: hidden;
		flex-direction: column;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: var(--surface);
		color: var(--ink);
		text-decoration: none;
	}
	ul li a:hover {
		border-color: #b6cbc4;
		box-shadow: var(--box-shadow);
	}
	ul li img {
		width: 100%;
		aspect-ratio: 16 / 10;
		object-fit: cover;
		border-radius: 0;
	}
	.card-copy {
		padding: 20px;
	}
	.title {
		margin: 0;
		color: var(--ink);
		font-size: 1.25rem;
		line-height: 1.2;
	}
	.date {
		margin: 0 0 8px;
		color: var(--warm);
		font-size: 0.78rem;
		font-weight: 700;
		text-transform: uppercase;
	}
	.description {
		margin: 10px 0 0;
		color: var(--muted);
		font-size: 0.95rem;
	}
	@media (max-width: 860px) {
		ul {
			grid-template-columns: 1fr;
		}
		ul li:first-child {
			grid-column: auto;
		}
	}
</style>
