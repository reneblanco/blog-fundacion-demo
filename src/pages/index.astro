---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const heroImage =
	'https://images.unsplash.com/photo-1488521787991-ed7bbaae773c?auto=format&fit=crop&w=1400&q=82';

const programs = [
	{
		title: 'Vivienda digna',
		description: 'Notas sobre mejoramiento de hogares, espacios seguros y acompanamiento familiar.',
		image:
			'https://images.unsplash.com/photo-1469571486292-0ba58a3f068b?auto=format&fit=crop&w=900&q=80',
		tag: 'Comunidad',
	},
	{
		title: 'Becas y aprendizaje',
		description: 'Historias de estudiantes, aliados educativos y rutas para abrir oportunidades.',
		image:
			'https://images.unsplash.com/photo-1497486751825-1233686d5d80?auto=format&fit=crop&w=900&q=80',
		tag: 'Educacion',
	},
	{
		title: 'Agua y territorio',
		description: 'Actualizaciones de campo sobre agua, reforestacion y cuidado de espacios comunes.',
		image:
			'https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=900&q=80',
		tag: 'Ambiente',
	},
];

const categories = [
	['Becas', 'Convocatorias, avances y testimonios de aprendizaje.'],
	['Agua', 'Proyectos de acceso, cuidado y cultura del agua.'],
	['Reforestacion', 'Jornadas, viveros, voluntariado y seguimiento.'],
	['Vivienda', 'Mejoras, acompanamiento y vida comunitaria.'],
	['Voluntariado', 'Formas de participar y cronicas de campo.'],
	['Transparencia', 'Reportes, metas e indicadores faciles de leer.'],
];

const stats = [
	['120+', 'familias acompanadas'],
	['18', 'jornadas comunitarias'],
	['6', 'programas activos'],
];

const newsletterTopics = [
	'Convocatorias abiertas',
	'Historias de campo',
	'Fechas de voluntariado',
	'Reportes breves de avance',
];

const updates = [
	{
		title: 'Abre la convocatoria de becas comunitarias 2026',
		type: 'Becas',
		image:
			'https://images.unsplash.com/photo-1523580846011-d3a5bc25702b?auto=format&fit=crop&w=900&q=80',
	},
	{
		title: 'Jornada de reforestacion en espacios vecinales',
		type: 'Reforestacion',
		image:
			'https://images.unsplash.com/photo-1542601906990-b4d3fb778b09?auto=format&fit=crop&w=900&q=80',
	},
	{
		title: 'Como se mide el avance de un programa de vivienda',
		type: 'Transparencia',
		image:
			'https://images.unsplash.com/photo-1494526585095-c41746248156?auto=format&fit=crop&w=900&q=80',
	},
];
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-copy">
					<p class="eyebrow">Fundación Casas Carpin</p>
					<h1>Historias publicas para contar impacto con claridad.</h1>
					<p>
						Un blog editorial para compartir avances, convocatorias, testimonios y recursos de
						la fundación. Diseñado para que el equipo publique sin fricción y la comunidad
						encuentre lo importante rápido.
					</p>
					<div class="hero-actions">
						<a href="/blog/">Leer historias</a>
						<a href="#participar">Participar</a>
					</div>
				</div>
				<div class="hero-media">
					<img src={heroImage} alt="Personas reunidas en una actividad comunitaria" />
					<div class="impact-card">
						<strong>Reporte abierto</strong>
						<span>Programas, becas, agua y comunidad en un solo archivo.</span>
					</div>
				</div>
			</section>

			<section class="ticker" aria-label="Avisos destacados">
				<span>Convocatoria de becas abierta</span>
				<span>Proxima jornada de reforestacion</span>
				<span>Reporte trimestral disponible</span>
			</section>

			<section class="section-block">
				<div class="section-heading">
					<div>
						<p class="eyebrow">Programas</p>
						<h2>Areas que una fundación puede contar con ritmo editorial.</h2>
					</div>
					<a href="/blog/">Ver archivo</a>
				</div>
				<div class="program-grid">
					{
						programs.map((program) => (
							<article>
								<img src={program.image} alt="" loading="lazy" />
								<div>
									<span>{program.tag}</span>
									<h3>{program.title}</h3>
									<p>{program.description}</p>
								</div>
							</article>
						))
					}
				</div>
			</section>

			<section class="split-band">
				<div>
					<p class="eyebrow">Categorías sugeridas</p>
					<h2>Un blog pensado para que la gente encuentre acciones, no solo comunicados.</h2>
					<p>
						Las categorías pueden cambiar cuando conozcamos mejor la fundación. Por ahora dejan
						claro que el sitio puede ordenar becas, agua, vivienda, voluntariado y reportes.
					</p>
				</div>
				<div class="category-grid">
					{
						categories.map(([title, description]) => (
							<a href="/blog/">
								<strong>{title}</strong>
								<span>{description}</span>
							</a>
						))
					}
				</div>
			</section>

			<section class="story-feature">
				<div class="video-card">
					<img
						src="https://images.unsplash.com/photo-1517048676732-d65bc937f952?auto=format&fit=crop&w=1200&q=80"
						alt="Equipo revisando ideas en una mesa de trabajo"
						loading="lazy"
					/>
					<span>Video / 03:24</span>
				</div>
				<div>
					<p class="eyebrow">Contenido multimedia</p>
					<h2>Espacio para videos de campo, entrevistas y cápsulas de transparencia.</h2>
					<p>
						La fundación puede publicar textos largos, galerías, videos embebidos o anuncios
						breves. Esta sección muestra cómo se vería una pieza audiovisual destacada.
					</p>
					<div class="stats">
						{
							stats.map(([number, label]) => (
								<div>
									<strong>{number}</strong>
									<span>{label}</span>
								</div>
							))
						}
					</div>
				</div>
			</section>

			<section class="newsletter">
				<div class="newsletter-copy">
					<p class="eyebrow">Boletín de campo</p>
					<h2>Una vez al mes, lo importante sin ruido.</h2>
					<p>
						Un correo breve para aliados, familias, voluntarios y donantes: avances reales,
						próximas fechas y oportunidades para participar.
					</p>
				</div>
				<div class="newsletter-panel">
					<div class="issue">
						<span>Próxima edición</span>
						<strong>Agosto / Vivienda y becas</strong>
					</div>
					<ul>
						{
							newsletterTopics.map((topic) => (
								<li>{topic}</li>
							))
						}
					</ul>
					<form class="newsletter-form" name="newsletter" method="POST" data-netlify="true" netlify-honeypot="company">
						<input type="hidden" name="form-name" value="newsletter" />
						<label class="sr-only" for="newsletter-email">Correo electrónico</label>
						<input class="newsletter-input" id="newsletter-email" type="email" name="email" placeholder="correo@ejemplo.com" required />
						<p class="hidden-field" hidden aria-hidden="true">
							<label>
								Empresa
								<input name="company" />
							</label>
						</p>
						<button class="newsletter-button" type="submit">Suscribirme</button>
					</form>
					<p class="form-note">Sin spam. Solo actualizaciones relevantes de la fundación.</p>
				</div>
			</section>

			<section class="section-block">
				<div class="section-heading">
					<div>
						<p class="eyebrow">Últimas publicaciones</p>
						<h2>Una primera vista para noticias, convocatorias y aprendizajes.</h2>
					</div>
					<a href="/blog/">Ver todas</a>
				</div>
				<div class="updates-grid">
					{
						updates.map((item) => (
							<article>
								<img src={item.image} alt="" loading="lazy" />
								<span>{item.type}</span>
								<h3>{item.title}</h3>
								<p>
									Texto de ejemplo para visualizar el espacio editorial antes de tener la
									información final del cliente.
								</p>
							</article>
						))
					}
				</div>
			</section>

			<section id="participar" class="cta">
				<div>
					<p class="eyebrow">Participa</p>
					<h2>Un cierre claro para donaciones, voluntariado o alianzas.</h2>
					<p>
						Aqui puede vivir una llamada a donar, registrarse como voluntario, descargar un
						reporte o contactar al equipo de la fundación.
					</p>
				</div>
				<div class="cta-actions">
					<a href="/about/">Conocer la fundación</a>
					<a href="/blog/">Leer el blog</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: min(1120px, calc(100% - 32px));
		padding-top: 34px;
	}
	.hero {
		display: grid;
		grid-template-columns: minmax(0, 0.94fr) minmax(360px, 1fr);
		gap: 48px;
		align-items: center;
		min-height: 620px;
		padding: 36px 0 70px;
	}
	.hero-copy {
		max-width: 620px;
	}
	.eyebrow {
		margin: 0 0 12px;
		color: var(--warm);
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0;
		text-transform: uppercase;
	}
	.hero h1 {
		margin-bottom: 20px;
		font-size: clamp(2.6rem, 7vw, 5.5rem);
		line-height: 0.98;
	}
	.hero-copy > p:not(.eyebrow),
	.split-band > div > p,
	.story-feature > div > p,
	.cta p {
		max-width: 610px;
		margin: 0;
		color: var(--muted);
		font-size: 1.04rem;
	}
	.hero-actions,
	.cta-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		margin-top: 28px;
	}
	.hero-actions a,
	.cta-actions a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 42px;
		padding: 0 18px;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: #fff;
		color: var(--ink);
		font-size: 0.9rem;
		font-weight: 800;
		text-decoration: none;
	}
	.hero-actions a:first-child,
	.cta-actions a:first-child {
		border-color: var(--accent-dark);
		background: var(--accent-dark);
		color: #fff;
	}
	.hero-media {
		position: relative;
	}
	.hero-media img {
		display: block;
		width: 100%;
		aspect-ratio: 4 / 5;
		object-fit: cover;
		border-radius: 8px;
		box-shadow: var(--box-shadow);
	}
	.impact-card {
		position: absolute;
		right: 22px;
		bottom: 22px;
		display: grid;
		gap: 4px;
		width: min(270px, calc(100% - 44px));
		padding: 18px;
		border: 1px solid rgba(255, 255, 255, 0.62);
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.92);
		backdrop-filter: blur(12px);
	}
	.impact-card strong {
		color: var(--ink);
	}
	.impact-card span {
		color: var(--muted);
		font-size: 0.9rem;
		line-height: 1.45;
	}
	.ticker {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		border-top: 1px solid var(--line);
		border-bottom: 1px solid var(--line);
	}
	.ticker span {
		padding: 18px;
		border-right: 1px solid var(--line);
		color: var(--accent-dark);
		font-size: 0.86rem;
		font-weight: 800;
		text-align: center;
	}
	.ticker span:last-child {
		border-right: 0;
	}
	.section-block,
	.split-band,
	.story-feature,
	.newsletter,
	.cta {
		padding: 72px 0;
		border-bottom: 1px solid var(--line);
	}
	.section-heading {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 24px;
		margin-bottom: 28px;
	}
	.section-heading h2,
	.split-band h2,
	.story-feature h2,
	.cta h2 {
		max-width: 720px;
		margin: 0;
		font-size: clamp(1.8rem, 4vw, 3rem);
		line-height: 1.04;
	}
	.section-heading a {
		color: var(--ink);
		font-size: 0.9rem;
		font-weight: 800;
		text-decoration: none;
	}
	.program-grid,
	.updates-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 18px;
	}
	.program-grid article,
	.updates-grid article {
		overflow: hidden;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: #fff;
	}
	.program-grid img,
	.updates-grid img {
		display: block;
		width: 100%;
		aspect-ratio: 16 / 11;
		object-fit: cover;
		border-radius: 0;
	}
	.program-grid article > div {
		padding: 18px;
	}
	.program-grid span,
	.updates-grid span,
	.video-card span {
		display: inline-flex;
		margin-bottom: 10px;
		padding: 5px 8px;
		border-radius: 6px;
		background: #fff3cf;
		color: #6b4a00;
		font-size: 0.72rem;
		font-weight: 800;
	}
	.program-grid h3,
	.updates-grid h3 {
		margin: 0 0 8px;
		font-size: 1.2rem;
		line-height: 1.18;
	}
	.program-grid p,
	.updates-grid p {
		margin: 0;
		color: var(--muted);
		font-size: 0.94rem;
		line-height: 1.5;
	}
	.split-band,
	.story-feature,
	.newsletter,
	.cta {
		display: grid;
		grid-template-columns: minmax(0, 0.8fr) minmax(360px, 1fr);
		gap: 46px;
		align-items: center;
	}
	.category-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 12px;
	}
	.category-grid a {
		display: grid;
		gap: 7px;
		min-height: 112px;
		padding: 18px;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: #fff;
		color: var(--ink);
		text-decoration: none;
	}
	.category-grid span {
		color: var(--muted);
		font-size: 0.86rem;
		line-height: 1.45;
	}
	.video-card {
		position: relative;
		order: -1;
	}
	.video-card img {
		display: block;
		width: 100%;
		aspect-ratio: 16 / 11;
		object-fit: cover;
		border-radius: 8px;
	}
	.video-card span {
		position: absolute;
		left: 18px;
		bottom: 18px;
		margin: 0;
		background: rgba(255, 255, 255, 0.94);
		color: var(--ink);
	}
	.stats {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 10px;
		margin-top: 28px;
	}
	.stats div {
		padding: 16px;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: #fff;
	}
	.stats strong,
	.stats span {
		display: block;
	}
	.stats strong {
		font-size: 1.6rem;
	}
	.stats span {
		color: var(--muted);
		font-size: 0.82rem;
	}
	.newsletter {
		align-items: stretch;
	}
	.newsletter-copy {
		display: flex;
		flex-direction: column;
		justify-content: center;
		padding: 42px;
		border-radius: 8px;
		background: #17211d;
		color: #fff;
	}
	.newsletter-copy .eyebrow {
		color: #f2bd3c;
	}
	.newsletter-copy h2 {
		max-width: 560px;
		margin: 0;
		color: #fff;
		font-size: clamp(2rem, 4vw, 3.35rem);
		line-height: 1;
	}
	.newsletter-copy p:not(.eyebrow) {
		max-width: 520px;
		margin: 18px 0 0;
		color: rgba(255, 255, 255, 0.74);
	}
	.newsletter-panel {
		display: grid;
		align-content: center;
		gap: 22px;
		padding: 34px;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: #fff;
	}
	.issue {
		display: grid;
		gap: 4px;
		padding-bottom: 18px;
		border-bottom: 1px solid var(--line);
	}
	.issue span {
		color: var(--warm);
		font-size: 0.78rem;
		font-weight: 800;
		text-transform: uppercase;
	}
	.issue strong {
		font-size: 1.4rem;
		line-height: 1.1;
	}
	.newsletter ul {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 8px 14px;
		margin: 0;
		padding: 0;
		list-style: none;
	}
	.newsletter li {
		color: var(--muted);
		font-size: 0.92rem;
	}
	.newsletter li::before {
		content: "";
		display: inline-block;
		width: 7px;
		height: 7px;
		margin-right: 8px;
		border-radius: 50%;
		background: var(--sun);
		vertical-align: middle;
	}
	.newsletter-form {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 8px;
	}
	.newsletter-input {
		min-width: 0;
		height: 44px;
		padding: 0 14px;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: #fbfcf8;
		color: var(--ink);
		font: inherit;
	}
	.newsletter-button {
		height: 44px;
		padding: 0 16px;
		border: 0;
		border-radius: 8px;
		background: var(--accent-dark);
		color: #fff;
		font: inherit;
		font-size: 0.9rem;
		font-weight: 800;
		cursor: pointer;
	}
	.form-note {
		margin: 0;
		color: var(--muted);
		font-size: 0.82rem;
	}
	.hidden-field {
		display: none !important;
	}
	.updates-grid article {
		padding: 0 0 18px;
	}
	.updates-grid article > *:not(img) {
		margin-left: 18px;
		margin-right: 18px;
	}
	.cta {
		margin-top: 72px;
		padding: 46px;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: #eef6f1;
	}
	.cta-actions {
		justify-content: flex-end;
		margin-top: 0;
	}
	@media (max-width: 860px) {
		main {
			width: min(100% - 24px, 1120px);
			padding-top: 18px;
		}
		.hero,
		.split-band,
		.story-feature,
		.newsletter,
		.cta {
			grid-template-columns: 1fr;
		}
		.hero {
			min-height: auto;
			gap: 28px;
			padding-bottom: 44px;
		}
		.hero-media img {
			aspect-ratio: 16 / 11;
		}
		.ticker,
		.program-grid,
		.updates-grid,
		.category-grid,
		.stats {
			grid-template-columns: 1fr;
		}
		.ticker span {
			border-right: 0;
			border-bottom: 1px solid var(--line);
		}
		.ticker span:last-child {
			border-bottom: 0;
		}
		.section-heading,
		.cta-actions {
			align-items: flex-start;
			flex-direction: column;
		}
		.section-block,
		.split-band,
		.story-feature,
		.newsletter {
			padding: 48px 0;
		}
		.newsletter-copy,
		.newsletter-panel {
			padding: 26px 20px;
		}
		.newsletter-form,
		.newsletter ul {
			grid-template-columns: 1fr;
		}
		.cta {
			margin-top: 48px;
			padding: 28px 20px;
		}
	}
</style>
