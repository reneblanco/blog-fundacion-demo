---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const featuredNotes = [
	{
		title: 'Recovery is a journey we can take together',
		description:
			'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer facilisis, augue vel luctus.',
		image: 'https://picsum.photos/seed/memoblog-recovery/900/1100',
		tags: ['Comunidad', 'Salud'],
	},
	{
		title: 'Bring your own bag: small habits, large futures',
		description:
			'Praesent vitae libero sed arcu pulvinar posuere. Donec porttitor lorem sed urna.',
		image: 'https://picsum.photos/seed/memoblog-bags/900/1100',
		tags: ['Sostenible', 'Campana'],
	},
	{
		title: 'Bold voices for brighter neighborhoods',
		description:
			'Sed non mauris sit amet metus volutpat gravida. Nam euismod lectus nec mi.',
		image: 'https://picsum.photos/seed/memoblog-red/900/1100',
		tags: ['Historias', 'Impacto'],
	},
	{
		title: 'Dream in denim: youth programs that move',
		description:
			'Curabitur a magna eget orci vestibulum vulputate. Etiam feugiat mi eget felis.',
		image: 'https://picsum.photos/seed/memoblog-denim/900/1100',
		tags: ['Juventud', 'Cultura'],
	},
	{
		title: 'Organize your time, organize your care',
		description:
			'Morbi congue, leo non fermentum viverra, nunc nisl bibendum velit, vel posuere.',
		image: 'https://picsum.photos/seed/memoblog-time/900/1100',
		tags: ['Recursos', 'Guia'],
	},
	{
		title: 'Lost in you: stories from the field',
		description:
			'Vivamus consequat sapien non nisi laoreet, sed eleifend mi viverra. Aliquam erat.',
		image: 'https://picsum.photos/seed/memoblog-film/900/1100',
		tags: ['Cronica', 'Campo'],
	},
];

const tools = [
	'Investigacion comunitaria',
	'Publicacion rapida',
	'Archivo visual',
	'Boletin mensual',
];

const testimonials = [
	['Emma Rodriguez', 'El equipo logro convertir ideas dispersas en una historia clara y facil de publicar.'],
	['Patricia Wang', 'La experiencia editorial quedo simple, ordenada y muy amable para el equipo.'],
	['Sarah Mitchell', 'Cada entrada se siente consistente sin perder el tono humano de la organizacion.'],
	['David Patel', 'El flujo de publicar desde el admin reduce friccion y nos ahorra muchisimo tiempo.'],
	['James Chen', 'Un sitio rapido, limpio y listo para crecer con nuevas secciones.'],
	['Michael Thompson', 'La maqueta explica el concepto de inmediato y se ve lista para presentar.'],
];

const news = [
	{
		title: 'Minimalism vs. maximalism: finding your voice',
		image: 'https://picsum.photos/seed/memoblog-news-a/900/620',
	},
	{
		title: 'Responsive motion design for human stories',
		image: 'https://picsum.photos/seed/memoblog-news-b/900/620',
	},
	{
		title: 'Strategic brand identity for lasting trust',
		image: 'https://picsum.photos/seed/memoblog-news-c/900/620',
	},
];
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<p class="wave">* * *</p>
				<h1>Hey, somos Memoblog. Convertimos historias en publicaciones claras.</h1>
				<p>
					Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer posuere, lorem a
					convallis gravida, justo sem luctus neque, vitae feugiat sapien nunc non nulla.
				</p>
				<a href="/admin/" class="hero-button">Entrar al admin</a>
			</section>

			<div class="status-bar">
				<span>CDMX, Mexico</span>
				<a href="/blog/">GMT-6&nbsp;&nbsp; Abrir archivo editorial -></a>
			</div>

			<section class="section-block">
				<div class="section-heading">
					<div>
						<h2>Notas destacadas</h2>
						<p>Una maqueta de entradas falsas para mostrar ritmo, imagen y jerarquia visual.</p>
					</div>
					<a href="/blog/">Ver todo -></a>
				</div>
				<div class="project-grid">
					{
						featuredNotes.map((note) => (
							<article class="project-card">
								<img src={note.image} alt="" loading="lazy" />
								<h3>{note.title}</h3>
								<p>{note.description}</p>
								<div class="tags">
									{note.tags.map((tag) => (
										<span>{tag}</span>
									))}
								</div>
							</article>
						))
					}
				</div>
			</section>

			<section class="tools-band">
				<h2>Temas que ayudan a entregar experiencias editoriales limpias</h2>
				<div>
					{
						tools.map((tool) => (
							<span>{tool}</span>
						))
					}
				</div>
			</section>

			<section class="about-split">
				<div>
					<p class="quote-mark">"</p>
					<h2>Disenamos espacios digitales que convierten avances en confianza.</h2>
					<p>
						Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed dignissim suscipit
						orci, at tincidunt sem luctus ut. Aenean posuere ipsum eu augue pretium, id
						sagittis arcu interdum.
					</p>
					<a href="/about/">Sobre el proyecto</a>
				</div>
				<img src="https://picsum.photos/seed/memoblog-portrait/900/900" alt="" loading="lazy" />
			</section>

			<section class="testimonials">
				<div class="center-heading">
					<h2>Resultados reales, historias falsas para llenar espacio</h2>
					<p>Estos textos son de ejemplo y se reemplazan por testimonios reales cuando toque.</p>
				</div>
				<div class="testimonial-grid">
					{
						testimonials.map(([name, text]) => (
							<article>
								<strong>{name}</strong>
								<span>Aliado del proyecto</span>
								<p>{text}</p>
							</article>
						))
					}
				</div>
			</section>

			<section class="section-block">
				<div class="section-heading">
					<div>
						<h2>Noticias y pensamientos</h2>
						<p>Una coleccion de notas, recursos y anuncios para mostrar el sistema editorial.</p>
					</div>
					<a href="/blog/">Ver todo -></a>
				</div>
				<div class="news-grid">
					{
						news.map((item) => (
							<article>
								<img src={item.image} alt="" loading="lazy" />
								<small>02 Mayo 2026</small>
								<h3>{item.title}</h3>
								<p>
									Sit proin a dictum donec non orci. Vestibulum ante ipsum primis in faucibus.
								</p>
								<span>Digital</span>
							</article>
						))
					}
				</div>
			</section>

			<section class="cta">
				<div>
					<h2>Listos para presentar una idea de blog mas pulida?</h2>
					<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Donec vel neque sed.</p>
				</div>
				<a href="/admin/">Entrar al admin</a>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: min(980px, calc(100% - 32px));
		padding-top: 46px;
	}
	.hero {
		display: grid;
		justify-items: center;
		min-height: 330px;
		padding: 64px 16px 52px;
		text-align: center;
	}
	.wave {
		margin: 0 0 22px;
		color: var(--warm);
		font-weight: 700;
	}
	.hero h1 {
		max-width: 620px;
		margin-bottom: 18px;
		font-size: 2.65rem;
		line-height: 1.05;
	}
	.hero p:not(.wave) {
		max-width: 620px;
		margin: 0;
		color: var(--muted);
		font-size: 0.9rem;
	}
	.hero-button,
	.about-split a,
	.cta a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 34px;
		margin-top: 24px;
		padding: 0 16px;
		border-radius: 7px;
		background: #111;
		color: #fff;
		font-size: 0.78rem;
		font-weight: 700;
		text-decoration: none;
	}
	.status-bar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 16px;
		padding: 12px 22px;
		border-top: 1px solid #eceff1;
		border-bottom: 1px solid #eceff1;
		color: var(--muted);
		font-size: 0.68rem;
		font-weight: 700;
		text-transform: uppercase;
	}
	.status-bar a {
		padding: 6px 12px;
		border: 1px solid #9be7bd;
		border-radius: 999px;
		background: #edfff5;
		color: #148246;
		text-decoration: none;
	}
	.section-block,
	.tools-band,
	.about-split,
	.testimonials,
	.cta {
		padding: 56px 0;
		border-bottom: 1px solid #eceff1;
	}
	.section-heading {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 24px;
		margin-bottom: 30px;
	}
	.section-heading h2,
	.center-heading h2 {
		margin: 0 0 8px;
		font-size: 1.35rem;
	}
	.section-heading p,
	.center-heading p {
		max-width: 560px;
		margin: 0;
		color: var(--muted);
		font-size: 0.82rem;
	}
	.section-heading a {
		color: var(--ink);
		font-size: 0.78rem;
		font-weight: 700;
		text-decoration: none;
	}
	.project-grid,
	.news-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 22px;
	}
	.project-card img,
	.news-grid img {
		width: 100%;
		aspect-ratio: 4 / 5;
		object-fit: cover;
		border-radius: 8px;
	}
	.project-card h3,
	.news-grid h3 {
		margin: 14px 0 6px;
		font-size: 1rem;
		line-height: 1.15;
	}
	.project-card p,
	.news-grid p {
		margin: 0;
		color: var(--muted);
		font-size: 0.78rem;
		line-height: 1.45;
	}
	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
		margin-top: 12px;
	}
	.tags span,
	.news-grid span {
		display: inline-flex;
		padding: 4px 7px;
		border: 1px solid #e2e7ea;
		border-radius: 5px;
		color: var(--muted);
		font-size: 0.65rem;
	}
	.tools-band {
		text-align: center;
	}
	.tools-band h2 {
		margin: 0 auto 24px;
		max-width: 640px;
		font-size: 1.1rem;
	}
	.tools-band div {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		border: 1px solid #eceff1;
		border-radius: 8px;
		background: #fff;
	}
	.tools-band span {
		padding: 18px 14px;
		border-right: 1px solid #eceff1;
		color: var(--muted);
		font-size: 0.78rem;
		font-weight: 700;
	}
	.tools-band span:last-child {
		border-right: 0;
	}
	.about-split {
		display: grid;
		grid-template-columns: minmax(0, 0.95fr) minmax(280px, 1fr);
		gap: 54px;
		align-items: center;
	}
	.quote-mark {
		margin: 0 0 10px;
		color: #2458ff;
		font-size: 3.2rem;
		font-weight: 700;
		line-height: 0.8;
	}
	.about-split h2 {
		max-width: 460px;
		font-size: 2rem;
	}
	.about-split p:not(.quote-mark) {
		color: var(--muted);
		font-size: 0.86rem;
	}
	.about-split img {
		width: 100%;
		aspect-ratio: 1 / 1;
		object-fit: cover;
		border-radius: 8px;
	}
	.center-heading {
		margin-bottom: 28px;
		text-align: center;
	}
	.center-heading p {
		margin: 0 auto;
	}
	.testimonial-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 14px;
	}
	.testimonial-grid article {
		min-height: 120px;
		padding: 18px;
		border: 1px solid #eceff1;
		border-radius: 8px;
		background: #fff;
	}
	.testimonial-grid strong,
	.testimonial-grid span {
		display: block;
	}
	.testimonial-grid strong {
		font-size: 0.82rem;
	}
	.testimonial-grid span,
	.testimonial-grid p,
	.news-grid small {
		color: var(--muted);
		font-size: 0.72rem;
	}
	.testimonial-grid p {
		margin: 12px 0 0;
		line-height: 1.5;
	}
	.news-grid img {
		aspect-ratio: 16 / 10;
	}
	.news-grid small {
		display: block;
		margin-top: 12px;
	}
	.cta {
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 28px;
		align-items: center;
		padding: 64px 56px;
		border: 1px solid #eceff1;
		border-radius: 8px;
		background: #fff;
	}
	.cta h2 {
		max-width: 560px;
		font-size: 2rem;
	}
	.cta p {
		max-width: 500px;
		margin: 0;
		color: var(--muted);
		font-size: 0.86rem;
	}
	.cta a {
		margin-top: 0;
		background: #2458ff;
	}
	@media (max-width: 860px) {
		main {
			padding-top: 22px;
		}
		.hero {
			padding: 40px 0 34px;
		}
		.hero h1 {
			font-size: 2.15rem;
		}
		.status-bar,
		.section-heading,
		.cta {
			align-items: flex-start;
			flex-direction: column;
		}
		.project-grid,
		.news-grid,
		.testimonial-grid,
		.tools-band div,
		.about-split {
			grid-template-columns: 1fr;
		}
		.tools-band span {
			border-right: 0;
			border-bottom: 1px solid #eceff1;
		}
		.tools-band span:last-child {
			border-bottom: 0;
		}
		.cta {
			padding: 32px 22px;
		}
	}
</style>
