---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const pillars = [
	['Escuchar', 'Partir de las necesidades de cada comunidad antes de proponer soluciones.'],
	['Acompañar', 'Convertir programas de vivienda, becas y territorio en procesos sostenidos.'],
	['Rendir cuentas', 'Publicar avances, aprendizajes y resultados de forma clara y accesible.'],
];
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={`Fundación | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="about-hero">
				<div>
					<p class="eyebrow">Sobre la fundación</p>
					<h1>Un espacio para presentar propósito, programas y resultados.</h1>
				</div>
				<p>
					Esta página está preparada como base editorial mientras se define la información final
					de Casas Carpin Fundación. Puede explicar misión, ejes de trabajo, aliados, reportes y
					formas de participar.
				</p>
			</section>

			<section class="image-band">
				<img
					src="https://images.unsplash.com/photo-1521737604893-d14cc237f11d?auto=format&fit=crop&w=1400&q=82"
					alt="Equipo trabajando en una mesa"
				/>
			</section>

			<section class="pillars">
				{
					pillars.map(([title, description]) => (
						<article>
							<strong>{title}</strong>
							<p>{description}</p>
						</article>
					))
				}
			</section>

			<section class="note">
				<p class="eyebrow">Nota para presentar</p>
				<h2>La estructura ya soporta blog, categorías, contenido multimedia y llamadas a participar.</h2>
				<p>
					Lo siguiente sería reemplazar estos textos por misión real, programas confirmados,
					fotografías propias y datos de impacto de la fundación.
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: min(1120px, calc(100% - 32px));
	}
	.about-hero {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(320px, 0.7fr);
		gap: 48px;
		align-items: end;
		padding: 60px 0 44px;
	}
	.eyebrow {
		margin: 0 0 12px;
		color: var(--warm);
		font-size: 0.78rem;
		font-weight: 800;
		text-transform: uppercase;
	}
	h1 {
		max-width: 820px;
		font-size: clamp(2.3rem, 5vw, 4.8rem);
		line-height: 1;
	}
	.about-hero p:not(.eyebrow),
	.note p {
		margin: 0;
		color: var(--muted);
		font-size: 1.02rem;
	}
	.image-band img {
		display: block;
		width: 100%;
		max-height: 520px;
		object-fit: cover;
		border-radius: 8px;
	}
	.pillars {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 14px;
		padding: 28px 0 72px;
	}
	.pillars article {
		padding: 22px;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: #fff;
	}
	.pillars strong {
		font-size: 1.1rem;
	}
	.pillars p {
		margin: 10px 0 0;
		color: var(--muted);
		font-size: 0.94rem;
	}
	.note {
		padding: 48px;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: #eef6f1;
	}
	.note h2 {
		max-width: 760px;
		font-size: clamp(1.8rem, 4vw, 3rem);
		line-height: 1.05;
	}
	.note p {
		max-width: 620px;
	}
	@media (max-width: 780px) {
		main {
			width: min(100% - 24px, 1120px);
		}
		.about-hero,
		.pillars {
			grid-template-columns: 1fr;
		}
		.note {
			padding: 28px 20px;
		}
	}
</style>
