---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={`Proyecto | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="about">
				<p class="eyebrow">Proyecto demo</p>
				<h1>Un blog facil de administrar, listo para crecer con la organizacion.</h1>
				<p>
					Este sitio combina un frontend ligero en Astro con un panel editorial en /admin. El
					equipo puede publicar entradas sin tocar codigo y Netlify se encarga de reconstruir el
					sitio automaticamente.
				</p>
				<div class="features">
					<div>
						<strong>Publicacion simple</strong>
						<span>Campos claros para titulo, fecha, imagen y contenido.</span>
					</div>
					<div>
						<strong>Bajo mantenimiento</strong>
						<span>Sin base de datos tradicional ni servidor que administrar.</span>
					</div>
					<div>
						<strong>Rapido y seguro</strong>
						<span>Contenido estatico servido desde Netlify.</span>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.about {
		max-width: 820px;
	}
	.eyebrow {
		margin: 0 0 12px;
		color: var(--warm);
		font-size: 0.78rem;
		font-weight: 700;
		text-transform: uppercase;
	}
	.about > p:not(.eyebrow) {
		color: var(--muted);
		font-size: 1.1rem;
	}
	.features {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 14px;
		margin-top: 36px;
	}
	.features div {
		padding: 20px;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: var(--surface);
	}
	.features strong,
	.features span {
		display: block;
	}
	.features span {
		margin-top: 8px;
		color: var(--muted);
		font-size: 0.95rem;
	}
	@media (max-width: 760px) {
		.features {
			grid-template-columns: 1fr;
		}
	}
</style>
