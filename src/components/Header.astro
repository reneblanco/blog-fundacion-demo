---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a class="brand" href="/" aria-label="Ir al inicio">
			<span class="brand-mark">CC</span>
			<span>
				<strong>{SITE_TITLE}</strong>
				<small>Archivo de impacto</small>
			</span>
		</a>
		<div class="internal-links">
			<HeaderLink href="/">Inicio</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">Fundación</HeaderLink>
			<a class="subscribe-link" href="/blog/">Historias</a>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 10;
		border-bottom: 1px solid #eceff1;
		background: rgba(255, 255, 255, 0.96);
		backdrop-filter: blur(12px);
	}
	.brand {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		text-decoration: none;
	}
	.brand span:last-child {
		display: grid;
		gap: 1px;
	}
	.brand strong {
		color: var(--ink);
		font-size: 0.86rem;
		line-height: 1;
	}
	.brand small {
		color: var(--muted);
		font-size: 0.68rem;
		line-height: 1;
	}
	.brand-mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 34px;
		height: 34px;
		border-radius: 8px;
		background: #17211d;
		color: #fff;
		font-size: 0.72rem;
		font-weight: 800;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: min(980px, calc(100% - 32px));
		min-height: 56px;
		margin: 0 auto;
		gap: 24px;
	}
	.internal-links {
		display: flex;
		align-items: center;
		gap: 6px;
	}
	nav a {
		padding: 8px 10px;
		color: var(--muted);
		border-radius: 7px;
		text-decoration: none;
		font-size: 0.78rem;
	}
	nav a.active {
		background: #f2f6f4;
		color: var(--accent-dark);
		font-weight: 700;
	}
	.icon-link,
	.subscribe-link {
		border: 1px solid #e6eaed;
		background: #fff;
		color: var(--ink);
	}
	.icon-link {
		width: 30px;
		padding: 7px 0;
		text-align: center;
		font-weight: 700;
	}
	.subscribe-link {
		background: #fff8df;
		border-color: #f4d984;
		color: #5b4211;
		font-weight: 700;
	}
	@media (max-width: 720px) {
		nav {
			align-items: flex-start;
			flex-direction: column;
			padding: 14px 0;
			gap: 10px;
		}
		.internal-links {
			width: 100%;
			overflow-x: auto;
		}
	}
</style>
