---
const today = new Date();
---

<footer>
	<div>
		<strong>Memoblog</strong>
		<p>Historias, avances y aprendizajes para una comunidad mejor informada.</p>
	</div>
	<p class="copyright">&copy; {today.getFullYear()} Memoblog. Todos los derechos reservados.</p>
</footer>
<style>
	footer {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 24px;
		width: min(1120px, calc(100% - 32px));
		margin: 0 auto;
		padding: 42px 0 56px;
		border-top: 1px solid var(--line);
		color: var(--muted);
	}
	strong {
		color: var(--ink);
	}
	p {
		max-width: 420px;
		margin: 8px 0 0;
		font-size: 0.95rem;
	}
	.copyright {
		text-align: right;
	}
	@media (max-width: 720px) {
		footer {
			flex-direction: column;
		}
		.copyright {
			text-align: left;
		}
	}
</style>
