---
const today = new Date();
---

<footer>
	<div>
		<strong>Casas Carpin Fundación</strong>
		<p>Historias, avances y aprendizajes para cuidar comunidad, vivienda y territorio.</p>
	</div>
	<nav aria-label="Enlaces secundarios">
		<a href="/blog/">Blog</a>
		<a href="/about/">Fundación</a>
		<a href="/rss.xml">RSS</a>
	</nav>
	<p class="copyright">&copy; {today.getFullYear()} Casas Carpin Fundación.</p>
</footer>
<style>
	footer {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 24px;
		width: min(1120px, calc(100% - 32px));
		margin: 0 auto;
		padding: 42px 0 56px;
		border-top: 1px solid var(--line);
		color: var(--muted);
	}
	nav {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
	}
	a {
		color: var(--muted);
		font-size: 0.9rem;
		text-decoration: none;
	}
	a:hover {
		color: var(--accent-dark);
	}
	strong {
		color: var(--ink);
	}
	p {
		max-width: 420px;
		margin: 8px 0 0;
		font-size: 0.95rem;
	}
	.copyright {
		text-align: right;
	}
	@media (max-width: 720px) {
		footer {
			flex-direction: column;
		}
		.copyright {
			text-align: left;
		}
	}
</style>
