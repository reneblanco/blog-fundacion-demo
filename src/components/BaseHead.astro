---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import FallbackImage from '../assets/blog-placeholder-1.jpg';
import { SITE_TITLE } from '../consts';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, image = FallbackImage } = Astro.props;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<!-- Font preloads -->
<link rel="preload" href="/fonts/atkinson-regular.woff" as="font" type="font/woff" crossorigin />
<link rel="preload" href="/fonts/atkinson-bold.woff" as="font" type="font/woff" crossorigin />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image.src, Astro.url)} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image.src, Astro.url)} />

<!-- Capture Netlify Identity tokens before the widget can consume and clear the URL hash. -->
<script is:inline>
	(() => {
		const identityHashPattern = /(?:invite|confirmation|recovery|email_change)_token=/;
		const storedHash = sessionStorage.getItem('netlifyIdentityHash');

		if (identityHashPattern.test(window.location.hash)) {
			sessionStorage.setItem('netlifyIdentityHash', window.location.hash);

			if (window.location.pathname !== '/invite/') {
				window.location.replace(`/invite/${window.location.hash}`);
			}
			return;
		}

		if (window.location.pathname === '/invite/' && storedHash && identityHashPattern.test(storedHash)) {
			window.history.replaceState(null, '', `/invite/${storedHash}`);
		}
	})();
</script>

<!-- Netlify Identity must load on public pages so invite and recovery links can set passwords. -->
<script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
<script is:inline>
	window.addEventListener('load', () => {
		if (!window.netlifyIdentity) return;
		const identityHashPattern = /(?:invite|confirmation|recovery|email_change)_token=/;

		if (identityHashPattern.test(window.location.hash) && window.location.pathname !== '/invite/') {
			window.location.replace(`/invite/${window.location.hash}`);
			return;
		}

		window.netlifyIdentity.on('init', (user) => {
			if (!user) {
				window.netlifyIdentity.on('login', () => {
					document.location.href = '/admin/';
				});
			}
		});

		window.netlifyIdentity.init();
	});
</script>
